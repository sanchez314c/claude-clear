# Claude Clear Environment Configuration Example
# Copy this file to .env and configure as needed

# Development Mode
# DEBUG=false

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Backup Settings
# BACKUP_ENABLED=true
# BACKUP_RETENTION_DAYS=30

# Configuration File Path (default: ~/.claude.json)
# CLAUDE_CONFIG_PATH=

# Quiet Mode (suppress non-error output)
# QUIET=false

# Dry Run Mode (preview changes without applying)
# DRY_RUN=false
